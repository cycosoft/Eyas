{
  "name": "@cycosoft/eyas",
  "version": "1.0.0",
  "description": "Simplified Hands-on Testing for Web Applications",
  "main": "./out/main/index.js",
  "author": "Cycosoft, LLC (https://cycosoft.com)",
  "scripts": {
    "dev": "npm run compile:ui && electron-vite dev",
    "build": "npm run compile:ui && electron-vite build",
    "lint": "eslint .",
    "test": "npm run check",
    "check": "npm run test:interface:unit && npm run test:electron:unit && npm run test:electron:e2e && npm run lint && npm audit",
    "test:electron:e2e": "npm run build && playwright test",
    "test:electron:unit": "vitest run --config vitest.config.electron.js",
    "test:interface:unit": "vitest run --config vitest.config.interface.js",
    "compile:prep": "node src/scripts/compile-prep.js",
    "compile:ui": "vite build --config src/eyas-interface/app/.vite.config.ui.js && node src/scripts/copy-assets.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.4",
    "get-port": "^7.1.0",
    "mixpanel": "^0.20.0",
    "node-machine-id": "^1.1.12",
    "prompts": "^2.4.2",
    "selfsigned": "^5.5.0",
    "semver": "^7.7.4",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@mdi/font": "^7.4.47",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "electron": "^41.0.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "pinia": "^3.0.4",
    "sass": "^1.98.0",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^4.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.19",
    "vuetify": "^3.12.0"
  },
  "overrides": {
    "package-json": ">6.5.0 <8.0.0",
    "ws": "^7.0.0"
  }
}
