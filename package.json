{
  "name": "@cycosoft/eyas",
  "version": "1.0.0",
  "description": "Simplified Hands-on Testing for Web Applications",
  "main": "./out/main/index.js",
  "packageName": "Eyas Desktop",
  "author": "Cycosoft, LLC (https://cycosoft.com)",
  "homepage": "https://github.com/cycosoft/Eyas/releases",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cycosoft/Eyas.git"
  },
  "scripts": {
    "_______________DEV_______________": "",
    "dev": "npm run compile:ui && electron-vite dev",
    "dev:module": "npm run compile:module && electron .build/index.js --dev --trace-warnings",
    "dev:installer": "npm i && cross-env NODE_ENV=dev npm run compile:installer",
    "dev:ui": "npm i && npm run update && vite --config src/eyas-interface/app/.vite.config.ui.js --open",
    "dev:fixes": "sudo xattr -r -d com.apple.quarantine ./",
    "_____________TEST_______________": "",
    "check": "npm run test:interface:unit && npm run test:electron:unit && npm run test:electron:e2e && npm run lint && npm audit",
    "test:electron:e2e": "npm run build && playwright test",
    "test:electron:unit": "vitest run --config vitest.config.electron.js",
    "test:interface:unit": "vitest run --config vitest.config.interface.js",
    "_____________COMPILE_____________": "",
    "compile:prep": "node src/scripts/compile-prep.js",
    "compile:mac:copy": "mv ./.runners/mac-arm64/Eyas.app ./.runners/mac-arm64/Start.app && ditto -c -k --sequesterRsrc --keepParent ./.runners/mac-arm64/Start.app ./dist/runners/Start.app.zip",
    "compile:ui": "vite build --config src/eyas-interface/app/.vite.config.ui.js && node src/scripts/copy-assets.js",
    "compile:module": "electron-vite build && node src/scripts/compile-module.js",
    "compile:runner": "npm cache clean --force && node src/scripts/compile-runners.js",
    "compile:cleanup": "node src/scripts/compile-cleanup.js",
    "compile:mac": "npm run compile:prep && npm run compile:ui && npm run compile:module && npm run compile:runner && npm run compile:mac:copy && npm run compile:cleanup",
    "compile:mac:installer": "npm run compile:prep && npm run compile:ui && npm run compile:module && cross-env PUBLISH_TYPE=installer npm run compile:runner && npm run sign:mac:pkg && npm run notarize:pkg:output && npm run notarize:staple:pkg",
    "compile:installer": "npm run compile:prep && npm run compile:ui && npm run compile:module && cross-env PUBLISH_TYPE=installer npm run compile:runner",
    "_____________SIGNING_____________": "",
    "sign:win": "signtool sign /debug /n \"Open Source Developer, Eric Higginson\" /t http://time.certum.pl/ /fd sha256 /v ./dist/runners/Start.exe",
    "sign:win:verify": "signtool verify /pa ./dist/runners/Start.exe",
    "sign:mac:pkg": "dotenv -c -- npm run _encapsulated_sign:mac:pkg",
    "sign:mac:verify": "codesign -dvvv ./.runners/mac-arm64/Eyas.app",
    "sign:mac:pkg:verify": "pkgutil --check-signature ./.runners/EyasInstaller-mac.pkg",
    "notarize:zip": "ditto -c -k --sequesterRsrc --keepParent ./.runners/mac-arm64/Eyas.app ./.runners/mac-arm64/Eyas-for-notary.zip",
    "notarize": "xcrun notarytool submit ./.runners/mac-arm64/Eyas-for-notary.zip --keychain-profile \"Eyas\" --wait",
    "notarize:pkg:output": "xcrun notarytool submit ./.runners/EyasInstaller-mac.pkg --keychain-profile \"Eyas\" --wait",
    "notarize:verify": "spctl -a -vvv -t install ./.runners/mac-arm64/Eyas.app",
    "notarize:verify:pkg": "spctl -a -vvv -t install ./.runners/EyasInstaller-mac.pkg",
    "notarize:staple": "xcrun stapler staple ./.runners/mac-arm64/Eyas.app",
    "notarize:staple:verify": "xcrun stapler validate ./.runners/mac-arm64/Eyas.app",
    "notarize:staple:pkg": "xcrun stapler staple ./.runners/EyasInstaller-mac.pkg",
    "notarize:staple:verify:pkg": "xcrun stapler validate ./.runners/EyasInstaller-mac.pkg",
    "notarize:log": "xcrun notarytool log PASTE_LOG_ID_HERE --keychain-profile \"Eyas\"",
    "_____________SCRIPTS_____________": "",
    "update": "npm-check-updates --interactive --format group,time",
    "lint": "eslint .",
    "_encapsulated_sign:mac:pkg": "mv ./.runners/EyasInstaller-mac.pkg ./.runners/EyasInstaller-mac-unsigned.pkg && productsign --sign \"$CERT_NAME\" ./.runners/EyasInstaller-mac-unsigned.pkg ./.runners/EyasInstaller-mac.pkg",
    "bump:build": "node src/scripts/bump-build-version.js"
  },
  "license": "MIT",
  "keywords": [
    "testing",
    "static",
    "web",
    "applications",
    "serverless",
    "eyas",
    "manual",
    "uat",
    "feature",
    "branch"
  ],
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "archiver": "^7.0.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.4",
    "get-port": "^7.1.0",
    "mixpanel": "^0.20.0",
    "node-machine-id": "^1.1.12",
    "prompts": "^2.4.2",
    "selfsigned": "^5.5.0",
    "semver": "^7.7.4",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/register": "^7.28.6",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@mdi/font": "^7.4.47",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "npm-check-updates": "^19.6.5",
    "pinia": "^3.0.4",
    "sass": "^1.98.0",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^4.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.19",
    "vuetify": "^3.12.0"
  },
  "overrides": {
    "package-json": ">6.5.0 <8.0.0",
    "ws": "^7.0.0"
  }
}
