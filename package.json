{
  "name": "@cycosoft/eyas",
  "version": "26.4.15352",
  "type": "module",
  "description": "Simplified Hands-on Testing for Web Applications",
  "main": "./out/main/index.js",
  "packageName": "Eyas Desktop",
  "author": "Cycosoft, LLC (https://cycosoft.com)",
  "homepage": "https://github.com/cycosoft/Eyas/releases",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cycosoft/Eyas.git"
  },
  "scripts": {
    "_______________DEV_______________": "",
    "dev": "npm i && npm run update && electron-vite dev -- --dev",
    "dev:installer": "npm i && cross-env NODE_ENV=dev EYAS_OPEN_RUNNERS=true npm run compile:installer",
    "dev:fixes": "sudo xattr -r -d com.apple.quarantine ./",
    "_____________TEST_______________": "",
    "check": "npm run type-check && npm run audit-types && npm run test:interface:unit && npm run test:electron:unit && npm run test:electron:e2e && npm run lint && npm audit",
    "test:electron:e2e": "npm run compile:build && playwright test",
    "test:electron:unit": "vitest run --config vitest.config.electron.ts",
    "test:interface:unit": "vitest run --config vitest.config.interface.ts",
    "_____________COMPILE_____________": "",
    "compile:build": "npm run type-check && electron-vite build",
    "compile:mac:copy": "mv ./.runners/mac-arm64/Eyas.app ./.runners/mac-arm64/Start.app && ditto -c -k --sequesterRsrc --keepParent ./.runners/mac-arm64/Start.app ./dist/runners/Start.app.zip",
    "compile:runner": "npm cache clean --force && tsx src/scripts/compile-runners.ts",
    "compile:mac": "npm run compile:build && npm run compile:runner && npm run compile:mac:copy",
    "compile:mac:installer": "npm run compile:build && cross-env PUBLISH_TYPE=installer EYAS_OPEN_RUNNERS=true npm run compile:runner && npm run sign:mac:pkg && npm run notarize:pkg:output && npm run notarize:staple:pkg",
    "compile:installer": "npm run compile:build && cross-env PUBLISH_TYPE=installer EYAS_OPEN_RUNNERS=true npm run compile:runner",
    "_____________SIGNING_____________": "",
    "sign:win": "signtool sign /debug /n \"Open Source Developer, Eric Higginson\" /t http://time.certum.pl/ /fd sha256 /v ./dist/runners/Start.exe",
    "sign:win:verify": "signtool verify /pa ./dist/runners/Start.exe",
    "sign:mac:pkg": "dotenv -c -- npm run _encapsulated_sign:mac:pkg",
    "sign:mac:verify": "codesign -dvvv ./.runners/mac-arm64/Eyas.app",
    "sign:mac:pkg:verify": "pkgutil --check-signature ./.runners/EyasInstaller-mac.pkg",
    "notarize:zip": "ditto -c -k --sequesterRsrc --keepParent ./.runners/mac-arm64/Eyas.app ./.runners/mac-arm64/Eyas-for-notary.zip",
    "notarize": "xcrun notarytool submit ./.runners/mac-arm64/Eyas-for-notary.zip --keychain-profile \"Eyas\" --wait",
    "notarize:pkg:output": "xcrun notarytool submit ./.runners/EyasInstaller-mac.pkg --keychain-profile \"Eyas\" --wait",
    "notarize:verify": "spctl -a -vvv -t install ./.runners/mac-arm64/Eyas.app",
    "notarize:verify:pkg": "spctl -a -vvv -t install ./.runners/EyasInstaller-mac.pkg",
    "notarize:staple": "xcrun stapler staple ./.runners/mac-arm64/Eyas.app",
    "notarize:staple:verify": "xcrun stapler validate ./.runners/mac-arm64/Eyas.app",
    "notarize:staple:pkg": "xcrun stapler staple ./.runners/EyasInstaller-mac.pkg",
    "notarize:staple:verify:pkg": "xcrun stapler validate ./.runners/EyasInstaller-mac.pkg",
    "notarize:log": "xcrun notarytool log PASTE_LOG_ID_HERE --keychain-profile \"Eyas\"",
    "_____________SCRIPTS_____________": "",
    "update": "npm-check-updates --interactive --format group,time --cooldown 3",
    "audit-types": "knip",
    "type-check": "tsc -b",
    "lint": "eslint . --fix",
    "_encapsulated_sign:mac:pkg": "mv ./.runners/EyasInstaller-mac.pkg ./.runners/EyasInstaller-mac-unsigned.pkg && productsign --sign \"$CERT_NAME\" ./.runners/EyasInstaller-mac-unsigned.pkg ./.runners/EyasInstaller-mac.pkg",
    "bump:build": "tsx src/scripts/bump-build-version.ts"
  },
  "license": "MIT",
  "keywords": [
    "testing",
    "static",
    "web",
    "applications",
    "serverless",
    "eyas",
    "manual",
    "uat",
    "feature",
    "branch"
  ],
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "get-port": "^7.2.0",
    "mixpanel": "^0.21.0",
    "node-machine-id": "^1.1.12",
    "selfsigned": "^5.5.0",
    "semver": "^7.7.4",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@mdi/font": "^7.4.47",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6",
    "@types/semver": "^7.7.1",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.4.1",
    "npm-check-updates": "^20.0.0",
    "pinia": "^3.0.4",
    "sass": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.3.2",
    "vite-plugin-static-copy": "^4.0.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6",
    "vuetify": "^4.0.5"
  },
  "overrides": {
    "package-json": ">6.5.0 <8.0.0",
    "ws": "^7.0.0",
    "eslint-plugin-import": {
      "eslint": "$eslint"
    }
  }
}
