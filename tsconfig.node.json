{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["src/main/**/*", "src/preload/**/*", "src/eyas-core/**/*", "src/types/**/*", "src/scripts/**/*", "tests/electron/**/*", "tests/setup/**/*", "electron.vite.config.ts"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noImplicitAny": true,
    "types": ["node"],
    "allowJs": false,
    "verbatimModuleSyntax": true,
    "strictNullChecks": true
  }
}

