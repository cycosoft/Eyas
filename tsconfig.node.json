{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "src/path-aliases.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "src/eyas-core/**/*",
    "src/types/**/*",
    "src/scripts/**/*",
    "tests/electron/**/*",
    "tests/setup/**/*",
    "electron.vite.config.ts",
    "vitest.config.interface.ts",
    "vitest.config.electron.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noImplicitAny": true,
    "paths": {
      "@core/*": ["./src/eyas-core/*"],
      "@scripts/*": ["./src/scripts/*"],
      "@registry/*": ["./src/types/*"],
      "@assets/*": ["./src/eyas-assets/*"],
      "@setup/*": ["./tests/setup/*"],
      "@root/*": ["./*"]
    },
    "types": ["node"],
    "allowJs": false,
    "verbatimModuleSyntax": true,
    "strictNullChecks": true
  }
}
