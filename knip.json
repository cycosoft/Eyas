{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main/index.ts",
    "src/preload/index.ts",
    "src/eyas-interface/app/src/main.ts",
    "src/scripts/compile-runners.ts",
    "src/scripts/get-config.ts",
    "src/scripts/event-bridge.ts",
    "tests/e2e/**/*.spec.mjs",
    "tests/e2e/eyas-utils.mjs",
    "tests/unit/**/*.test.ts",
    "electron.vite.config.ts",
    ".eyas.config.js"
  ],
  "project": ["**/*.{ts,vue,mjs,js}"],
  "ignoreBinaries": [
    "ditto",
    "signtool",
    "codesign",
    "pkgutil",
    "xcrun",
    "spctl",
    "productsign",
    "sudo",
    "mv",
    "xattr"
  ],
  "ignoreDependencies": [
    "@mdi/font",
    "sass",
    "vue-tsc"
  ],
  "paths": {
    "@/*": ["src/eyas-interface/app/src/*"],
    "@core/*": ["src/eyas-core/*"],
    "@scripts/*": ["src/scripts/*"],
    "@registry/*": ["src/types/*"],
    "@assets/*": ["src/eyas-interface/app/src/assets/*"],
    "@interface/*": ["src/eyas-interface/app/src/*"]
  }
}
