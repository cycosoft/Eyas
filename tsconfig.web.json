{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/renderer/src/**/*", "src/renderer/src/**/*.vue"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "noImplicitAny": true,
    "paths": {
      "@/*": ["./src/renderer/src/*"]
    },
    "allowJs": false,
    "types": ["vite/client", "vitest/globals"],
    "verbatimModuleSyntax": true,
    "strictNullChecks": true
  }
}

