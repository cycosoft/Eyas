{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/renderer/src/**/*", "src/renderer/src/**/*.vue", "src/eyas-interface/app/src/**/*", "src/scripts/**/*", "src/types/**/*", "tests/unit/**/*", "tests/setup/vue-test-setup.ts"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "noImplicitAny": true,
    "paths": {
      "@/*": ["./src/eyas-interface/app/src/*"]
    },
    "allowJs": false,
    "types": ["vite/client", "vitest/globals"],
    "verbatimModuleSyntax": true,
    "strictNullChecks": true
  }
}

