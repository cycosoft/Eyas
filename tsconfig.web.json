{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/path-aliases.ts", "src/renderer/src/**/*", "src/renderer/src/**/*.vue", "src/eyas-interface/app/src/**/*", "src/scripts/**/*", "src/types/**/*", "tests/unit/**/*", "tests/setup/**/*"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "noImplicitAny": true,
    "paths": {
      "@core/*": ["./src/eyas-core/*"],
      "@scripts/*": ["./src/scripts/*"],
      "@registry/*": ["./src/types/*"],
      "@assets/*": ["./src/eyas-assets/*"],
      "@interface/*": ["./src/eyas-interface/app/src/*"],
      "@/*": ["./src/eyas-interface/app/src/*"]
    },
    "allowJs": false,
    "types": ["vite/client", "vitest/globals"],
    "verbatimModuleSyntax": true,
    "strictNullChecks": true
  }
}
